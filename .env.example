TELEGRAM_BOT_TOKEN=replace_me

# Kaggle credentials. The competition rules must be accepted once in a browser.
KAGGLE_USERNAME=replace_me
KAGGLE_KEY=replace_me
KAGGLE_COMPETITION=multi-view-pig-posture-recognition

DATA_DIR=/app/data
STATE_DIR=/app/state
AUTO_DOWNLOAD_DATASET=true

# Optional: comma-separated list of CSV stems to annotate. Empty means all unlabeled sources.
ANNOTATE_SOURCES=

# Optional: allow annotation of sources that already contain class_id.
INCLUDE_LABELED_SOURCES=false

LOG_LEVEL=INFO
